<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.smithandreah69.beamspot">

    <!-- ─── Internet & Network ─────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- ─── WiFi Scanning (real scan, required for SmartBridge mode) ── -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!--
        Android 9+: FINE_LOCATION is MANDATORY to read WiFi SSIDs and scan results.
        Without this the wifiManager.scanResults list returns empty or redacted SSIDs.
        The app MUST request this at runtime before scanning.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- ─── Hotspot / LocalOnlyHotspot ────────────────────────────── -->
    <!--
        CHANGE_WIFI_MULTICAST_STATE is needed to allow multicast packets through
        the hotspot so guest devices can discover the network properly.
    -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- ─── VPN (Smart Bridge Mode) ───────────────────────────────── -->
    <!--
        BIND_VPN_SERVICE is declared in the service tag below, not here.
        VPN permission itself is granted at runtime via VpnService.prepare().
        No manifest permission needed — Android handles it via the system dialog.
    -->

    <!-- ─── Foreground Service (keep VPN + hotspot alive) ─────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        Android 14+: must declare the foreground service type.
        DATA_SYNC covers our VPN traffic management use case.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- ─── Notifications ──────────────────────────────────────────── -->
    <!--
        Android 13+ (API 33+): POST_NOTIFICATIONS must be requested at runtime.
        Needed for session timer warnings and earning alerts.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ─── Battery Optimisation Exemption ────────────────────────── -->
    <!--
        Allows the app to ask the user to exempt it from Doze mode
        so the VPN / session timer keeps running when the screen is off.
        This opens the system "Battery optimisation" settings page.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- ─── Boot (restart VPN after phone reboot) ─────────────────── -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ─── Read network traffic stats (speed measurement) ───────── -->
    <uses-permission android:name="android.permission.READ_NETWORK_USAGE_HISTORY" tools:ignore="ProtectedPermissions" />

    <!-- ─── Modify system settings (WRITE_SETTINGS) for hotspot control ── -->
    <!--
        Item 36: Required to programmatically enable/disable WiFi hotspot.
        The system toggle may appear greyed out on some OEMs (Oplus/ColorOS).
        We use Settings.ACTION_MANAGE_WRITE_SETTINGS to request this.
    -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BeamSpot"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Main activity — single-activity Compose app -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            VPN Service for Smart Bridge Mode.
            android:permission restricts binding to system only.
            The service intercepts all IP traffic and enforces per-device
            session authorization.
        -->
        <service
            android:name=".BeamSpotVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Boot receiver — restarts VPN if host had it active before reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>

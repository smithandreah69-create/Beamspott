# =========================================================================
# BeamSpot Backend Environment Configuration Template (Railway Checklist)
# Copy these values and paste them into your Railway Service variables.
# =========================================================================

# Database Connection (PostgreSQL)
# e.g., postgresql://postgres:password@localhost:5432/beamspot
DATABASE_URL=your_postgresql_database_url_here

# JSON Web Token Secret (used to sign session/auth tokens securely)
# Generate a random string (e.g., openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_here

# Google Sign-In Client ID (Google OAuth 2.0 Web Client ID)
# Used to verify ID tokens received from the Android app
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# IntaSend Secret Key
# Used to authenticate API requests to IntaSend (e.g., ISSecretKey_...)
INTASEND_SECRET_KEY=ISSecretKey_your_intasend_secret_key_here

# IntaSend Public Key
# Used in the payment payload (e.g., ISPubKey_...)
INTASEND_PUBLIC_KEY=ISPubKey_your_intasend_public_key_here

# IntaSend Webhook Secret Token
# IntaSend sends this in the 'x-intasend-signature' header to authenticate webhook requests
INTASEND_WEBHOOK_SECRET=your_intasend_webhook_secret_here

# IntaSend API Base URL
# Use https://sandbox.intasend.com for development/testing, or https://payment.intasend.com for production
INTASEND_API_BASE_URL=https://sandbox.intasend.com

# Public Deployment Base URL (The base URL of this backend)
# Used to construct the payment redirect callback URL
# e.g., https://beamspot-backend.up.railway.app
PUBLIC_BASE_URL=https://your-backend.railway.app

# IntaSend Transaction Currency (default: KES)
# e.g., KES, USD
INTASEND_CURRENCY=KES

# Server Port (Railway will automatically inject this)
PORT=3000

# Gemini API Key (Optional — reserved for platform capabilities)
GEMINI_API_KEY=your_gemini_api_key_here
